# Skopiuj do .env i uzupełnij — .env jest w .gitignore

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=zmień_mnie_na_silne_hasło
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketing_autopilot

# Redis
REDIS_PASSWORD=zmień_mnie_na_silne_hasło

# MongoDB
MONGO_USER=app
MONGO_PASSWORD=zmień_mnie_na_silne_hasło
MONGO_HOST=localhost
MONGO_PORT=27017

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
SCHEMA_REGISTRY_URL=http://localhost:8081

# LangChain4j / OpenAI
OPENAI_API_KEY=sk-...twój_klucz...

# Instagram / Meta
META_APP_ID=
META_APP_SECRET=

# Google (Search Console + My Business)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Środowisko
APP_ENV=dev